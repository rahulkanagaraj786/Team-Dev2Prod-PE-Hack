# Application
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=false
FLASK_DEBUG=true

# Database — choose one of the two options below
# Option 1: full connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon_db

# Option 2: individual fields (used if DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hackathon_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Test database (used by pytest)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon_test_db

# Request logging
REQUEST_LOG_FILE=/tmp/eval_requests.log
LOG_WEBHOOK_URL=

# Control plane
CONTROL_PLANE_PORT=5001
CONTROL_PLANE_ALLOWED_ORIGIN=http://localhost:5000

# Workload / Kubernetes
WORKLOAD_API_URL=
WORKLOAD_DEPLOYMENT_NAME=
WORKLOAD_SERVICE_NAME=
CLUSTER_NAME=
CLUSTER_NAMESPACE=
CLUSTER_PROVIDER=
